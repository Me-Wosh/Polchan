{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Hangfire": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File", 
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Json.JsonFormatter"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PolchanDB": "",
    "HangfireConnection": ""
  },
  "MediatR": {
    "LicenseKey": ""
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "Polchan",
    "Audience": "PolchanAudience",
    "ExpirationInMinutes": 15
  },
  "Storage": {
    "Local": {
      "BasePath": "/opt/PolchanResources"
    }
  },
  "BackgroundJobs": {
    "ScheduledJobs": {
      "CommentCleanup": {
        "CronExpression": "0 * * * *"
      },
      "PostCleanup": {
        "CronExpression": "0 0 * * *"
      },
      "ThreadCleanup": {
        "CronExpression": "0 0 * * 0"
      }
    }
  }
}
